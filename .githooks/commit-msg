#!/usr/bin/env bash
# Enforces Conventional Commits on the commit subject line.
# Enable with: git config core.hooksPath .githooks

set -euo pipefail

msg_file="$1"
subject="$(head -n 1 "$msg_file")"

# Ignore merge commits and fixup/squash commits
if [[ "$subject" =~ ^Merge\  ]] || [[ "$subject" =~ ^(fixup|squash)! ]]; then
  exit 0
fi

pattern='^(feat|fix|chore|docs|refactor|test|style|perf|build|ci)(\([a-z0-9./-]+\))?!?: .+'

if ! [[ "$subject" =~ $pattern ]]; then
  echo "error: commit message does not follow Conventional Commits" >&2
  echo "  got:      $subject" >&2
  echo "  expected: <type>(<optional-scope>): <description>" >&2
  echo "  types:    feat, fix, chore, docs, refactor, test, style, perf, build, ci" >&2
  echo "  example:  feat(analytics): add channel comparison" >&2
  exit 1
fi
